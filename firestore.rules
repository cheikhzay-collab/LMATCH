// Firestore Security Rules for L'Conq
// Deploy with: firebase deploy --only firestore:rules
// Or paste directly in Firebase Console > Firestore > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    // Is the requesting user authenticated?
    function isAuth() {
      return request.auth != null;
    }

    // Is the requesting user the document owner?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Is the requesting user an admin?
    // Admins have a custom claim set via Firebase Admin SDK or Functions.
    function isAdmin() {
      return isAuth() && request.auth.token.role == 'admin';
    }

    // ── Users collection ─────────────────────────────────────────────────────
    // Each user can read/write only their own document.
    // Admins can read all user documents.
    match /users/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Progress subcollection — only the user themselves
      match /progress/{questionId} {
        allow read, write: if isOwner(uid);
      }

      // Mock exam history — only the user themselves
      match /mockHistory/{histId} {
        allow read, write: if isOwner(uid);
      }

      // Daily activity — only the user themselves
      match /activity/{day} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Exams collection ─────────────────────────────────────────────────────
    // Anyone authenticated can read active exams.
    // Only admins can create/update/delete.
    match /exams/{examId} {
      allow read:   if isAuth();
      allow create,
            update,
            delete: if isAdmin();
    }

    // ── Config documents (schools, plans) ────────────────────────────────────
    // Anyone authenticated can read config.
    // Only admins can write.
    match /config/{docId} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ── Activation codes ─────────────────────────────────────────────────────
    // Authenticated users can read a specific code (to redeem it).
    // Only admins can create codes.
    // Only authenticated users can mark a code as used (via update).
    match /activationCodes/{code} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      // Allow update only to mark as used — prevent arbitrary field changes
      allow update: if isAuth()
                    && request.resource.data.isUsed == true
                    && resource.data.isUsed == false;
      allow delete: if isAdmin();
    }
  }
}
